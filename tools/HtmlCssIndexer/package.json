{
  "name": "codemeridian-html-css-indexer",
  "version": "1.0.12",
  "description": "Internal HTML/CSS/SCSS worker for CodeMeridian.Indexer.",
  "private": true,
  "type": "module",
  "scripts": {
    "index": "tsx src/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc --outDir dist",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}

{
  "name": "codemeridian-ts-indexer",
  "version": "1.0.12",
  "description": "Internal TypeScript worker for CodeMeridian.Indexer.",
  "private": true,
  "type": "module",
  "scripts": {
    "index": "tsx src/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc --outDir dist",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.1.2",
    "@rolldown/binding-win32-x64-msvc": "^1.1.2"
  }
}

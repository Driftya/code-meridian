{
  "name": "codemeridian-ts-indexer",
  "version": "1.0.12",
  "description": "TypeScript codebase indexer for CodeMeridian — walks TS/TSX files with ts-morph and pushes the structural graph into Neo4j via the CodeMeridian REST API.",
  "private": true,
  "type": "module",
  "scripts": {
    "index": "tsx src/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc --outDir dist",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "find-up": "^7.0.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}

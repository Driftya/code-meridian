{
  "DatabaseTracing": {
    "Enabled": true,
    "ConfigurationVersion": 1,
    "MaxTablesPerOperation": 6,
    "Presets": [
      {
        "Id": "ef-core",
        "Strategy": "EfCore",
        "Provider": "EFCore",
        "Enabled": true,
        "Languages": [ "CSharp" ],
        "ReadMethods": [
          "ToList",
          "ToListAsync",
          "First",
          "FirstAsync",
          "FirstOrDefault",
          "FirstOrDefaultAsync",
          "Single",
          "SingleAsync",
          "SingleOrDefault",
          "SingleOrDefaultAsync",
          "Any",
          "AnyAsync",
          "Count",
          "CountAsync",
          "LongCount",
          "LongCountAsync",
          "Find",
          "FindAsync",
          "FromSql",
          "FromSqlRaw",
          "FromSqlInterpolated"
        ],
        "WriteMethods": [
          "Add",
          "AddAsync",
          "AddRange",
          "AddRangeAsync",
          "Update",
          "UpdateRange",
          "Remove",
          "RemoveRange",
          "ExecuteUpdate",
          "ExecuteUpdateAsync",
          "ExecuteDelete",
          "ExecuteDeleteAsync",
          "ExecuteSql",
          "ExecuteSqlRaw",
          "ExecuteSqlRawAsync",
          "ExecuteSqlInterpolated",
          "ExecuteSqlInterpolatedAsync"
        ],
        "StatementArgumentIndexes": [ 0 ],
        "ReceiverTextHints": [ "context", "db", "database" ],
        "ImportModuleHints": [],
        "StatementTextProperties": [ "CommandText" ],
        "CommandCreationTypeHints": [],
        "TableSources": [ "GenericTypeArgument", "ReceiverMemberName", "SqlText" ]
      },
      {
        "Id": "dapper",
        "Strategy": "Dapper",
        "Provider": "Dapper",
        "Enabled": true,
        "Languages": [ "CSharp" ],
        "ReadMethods": [
          "Query",
          "QueryAsync",
          "QueryFirst",
          "QueryFirstAsync",
          "QueryFirstOrDefault",
          "QueryFirstOrDefaultAsync",
          "QuerySingle",
          "QuerySingleAsync",
          "QuerySingleOrDefault",
          "QuerySingleOrDefaultAsync",
          "QueryMultiple",
          "QueryMultipleAsync",
          "ExecuteScalar",
          "ExecuteScalarAsync"
        ],
        "WriteMethods": [ "Execute", "ExecuteAsync" ],
        "StatementArgumentIndexes": [ 0 ],
        "ReceiverTextHints": [ "connection", "dbConnection", "sqlConnection", "npgsqlConnection" ],
        "ImportModuleHints": [],
        "StatementTextProperties": [ "CommandText" ],
        "CommandCreationTypeHints": [],
        "TableSources": [ "SqlText" ]
      },
      {
        "Id": "raw-sql",
        "Strategy": "RawSql",
        "Provider": "RawSql",
        "Enabled": true,
        "Languages": [ "CSharp" ],
        "ReadMethods": [ "ExecuteReader", "ExecuteReaderAsync", "ExecuteScalar", "ExecuteScalarAsync" ],
        "WriteMethods": [ "ExecuteNonQuery", "ExecuteNonQueryAsync" ],
        "StatementArgumentIndexes": [ 0 ],
        "ReceiverTextHints": [ "command", "dbCommand", "sqlCommand" ],
        "ImportModuleHints": [],
        "StatementTextProperties": [ "CommandText" ],
        "CommandCreationTypeHints": [ "DbCommand", "SqlCommand", "NpgsqlCommand", "MySqlCommand", "SqliteCommand", "OracleCommand" ],
        "TableSources": [ "SqlText" ]
      },
      {
        "Id": "prisma",
        "Strategy": "Prisma",
        "Provider": "Prisma",
        "Enabled": true,
        "Languages": [ "TypeScript" ],
        "ReadMethods": [ "findUnique", "findUniqueOrThrow", "findFirst", "findFirstOrThrow", "findMany", "aggregate", "count", "groupBy" ],
        "WriteMethods": [ "create", "createMany", "update", "updateMany", "upsert", "delete", "deleteMany" ],
        "StatementArgumentIndexes": [ 0 ],
        "ReceiverTextHints": [ "prisma", "tx" ],
        "ImportModuleHints": [ "@prisma/client" ],
        "StatementTextProperties": [ "CommandText" ],
        "CommandCreationTypeHints": [],
        "TableSources": [ "ReceiverMemberName" ]
      },
      {
        "Id": "knex",
        "Strategy": "Knex",
        "Provider": "Knex",
        "Enabled": true,
        "Languages": [ "TypeScript" ],
        "ReadMethods": [ "select", "first", "pluck" ],
        "WriteMethods": [ "insert", "update", "del", "delete", "truncate" ],
        "StatementArgumentIndexes": [ 0 ],
        "ReceiverTextHints": [ "knex", "db" ],
        "ImportModuleHints": [ "knex" ],
        "StatementTextProperties": [ "CommandText" ],
        "CommandCreationTypeHints": [],
        "TableSources": [ "FirstArgumentString", "FromMethodArgument", "IntoMethodArgument" ]
      },
      {
        "Id": "neo4j-cypher",
        "Strategy": "Cypher",
        "Provider": "Neo4j",
        "Enabled": true,
        "Languages": [ "CSharp", "TypeScript" ],
        "ReadMethods": [ "Run", "RunAsync", "ExecuteRead", "ExecuteReadAsync", "ExecuteWrite", "ExecuteWriteAsync", "ExecuteQuery" ],
        "WriteMethods": [ "Run", "RunAsync", "ExecuteRead", "ExecuteReadAsync", "ExecuteWrite", "ExecuteWriteAsync", "ExecuteQuery" ],
        "StatementArgumentIndexes": [ 0 ],
        "ReceiverTextHints": [ "session", "tx", "driver" ],
        "ImportModuleHints": [ "neo4j-driver" ],
        "StatementTextProperties": [ "CommandText" ],
        "CommandCreationTypeHints": [],
        "TableSources": [ "CypherText" ]
      }
    ]
  }
}

{
  "$schema": "./meridian.schema.json",
  "version": 1,
  "project": "{{project}}",
  "codeMeridianUrl": "{{codeMeridianUrl}}",
  "allowRepoScripts": true,
  "useGlobalCache": {{useGlobalCache}},
  "configurationFiles": [
    ".env",
    ".env.local",
    ".env.development",
    ".env.production",
    ".env.test",
    "appsettings.json",
    "appsettings.*.json",
    "appsettings.Development.json",
    "appsettings.Production.json",
    "appsettings.Local.json",
    "app.config",
    "web.config",
    "packages.config",
    "NuGet.config",
    "Directory.Build.props",
    "Directory.Build.targets",
    "host.json",
    "global.json",
    "launchSettings.json",
    "local.settings.json",
    "local.settings.*.json",
    "package.json",
    ".npmrc",
    ".nvmrc",
    ".eslintrc.json",
    ".prettierrc",
    "tsconfig.json",
    "tsconfig.*.json",
    "tsconfig.app.json",
    "tsconfig.node.json",
    "vite.config.ts",
    "vite.config.js",
    "vitest.config.ts",
    "jest.config.js",
    "eslint.config.js",
    "proxy.conf.json",
    "pnpm-workspace.yaml",
    "function.json",
    "meridian.json",
    "meridian.sample.json",
    "docker-compose.yml",
    "docker-compose.yaml",
    "docker-compose.*.yml",
    "docker-compose.*.yaml",
    "docker-compose.override.yml",
    "compose.yml",
    "compose.yaml",
    "compose.*.yml",
    "compose.*.yaml"
  ],
  "architecture": {
    "path": ".meridian/architecture.json"
  },
  "indexing": {
    "fileRoles": {
      "test": [
        "tests/**/*.cs",
        "test/**/*.cs",
        "**/*.Tests/**/*.cs",
        "**/*.Test/**/*.cs",
        "**/*Tests.cs",
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/*.test.tsx",
        "**/*.spec.tsx"
      ],
      "migration": [
        "**/Migrations/*.cs",
        "**/Migrations/**/*.cs"
      ],
      "snapshot": [
        "**/*ModelSnapshot.cs"
      ],
      "generated": [
        "**/*.g.cs",
        "**/*.generated.cs",
        "**/*.Designer.cs",
        "**/*.designer.cs",
        "**/openapi.generated.ts",
        "**/graphql.generated.ts"
      ],
      "buildArtifact": [
        "**/bin/**",
        "**/obj/**",
        "**/node_modules/**",
        "**/dist/**",
        "**/build/**",
        "**/coverage/**"
      ],
      "configuration": [
        "**/*Options.cs",
        "**/*Option.cs",
        "**/*Configuration.cs",
        "**/*Configurations.cs",
        "**/*Config.cs",
        "**/*Configs.cs",
        "**/*Setting.cs",
        "**/*Settings.cs",
        "**/*Options.ts",
        "**/*Option.ts",
        "**/*Configuration.ts",
        "**/*Configurations.ts",
        "**/*Config.ts",
        "**/*Configs.ts",
        "**/*Setting.ts",
        "**/*Settings.ts",
        "**/*Options.tsx",
        "**/*Option.tsx",
        "**/*Configuration.tsx",
        "**/*Configurations.tsx",
        "**/*Config.tsx",
        "**/*Configs.tsx",
        "**/*Setting.tsx",
        "**/*Settings.tsx",
        "**/*.config.ts",
        "**/*.configs.ts",
        "**/*.configuration.ts",
        "**/*.configurations.ts",
        "**/*.option.ts",
        "**/*.options.ts",
        "**/*.setting.ts",
        "**/*.settings.ts",
        "**/*.config.tsx",
        "**/*.configs.tsx",
        "**/*.configuration.tsx",
        "**/*.configurations.tsx",
        "**/*.option.tsx",
        "**/*.options.tsx",
        "**/*.setting.tsx",
        "**/*.settings.tsx"
      ]
    }
  },
  "analysis": {
    "staleKnowledge": {
      "skipHeuristicSourcePrefixes": [
        "docs/plans/",
        "docs/features/"
      ],
      "ignoredMentionTokens": [
        "ASP",
        "ASP.NET",
        "CodeMeridian.Indexer",
        "CodeMeridian.Indexer.Tests",
        "TypeScript",
        "JavaScript",
        "Node.js",
        "Neo4j",
        "Docker",
        "README",
        "README.md",
        "meridian.json",
        "mcp.json",
        "config.toml",
        "compose.codemeridian.yml",
        "docker-compose.yml",
        "ApiEndpoint",
        "Controller",
        "Command",
        "Import",
        "Identify",
        "Configure",
        "Constants",
        "Resolve",
        "MapGet",
        "MapPost",
        "MapPut",
        "MapDelete",
        "Expected",
        "Actual",
        "Example",
        "Examples",
        "Warning",
        "Warnings",
        "Notes"
      ],
      "codeLikeSuffixes": [
        "Service",
        "Repository",
        "Controller",
        "Handler",
        "Provider",
        "Factory",
        "Client",
        "Command",
        "Query",
        "Endpoint",
        "Endpoints",
        "Tool",
        "Tools",
        "Options",
        "Registry",
        "Context",
        "Builder",
        "Mapper",
        "Validator",
        "Exception",
        "Reader",
        "Writer",
        "Parser",
        "Resolver",
        "Indexer",
        "Ingester"
      ],
      "ignoredDottedSuffixes": [
        ".com",
        ".org",
        ".net",
        ".md",
        ".json",
        ".toml",
        ".yml",
        ".yaml",
        ".txt",
        ".sln",
        ".csproj",
        ".tsproj"
      ]
    },
    "ranking": {
      "preferProductionOverTests": true,
      "testPathContains": [
        "test",
        ".spec.",
        ".test."
      ],
      "infrastructureNameSuffixes": [
        "Options",
        "Endpoints",
        "Tools"
      ],
      "infrastructureNames": [
        "DependencyInjection",
        "Program",
        "Startup",
        "CompositionRoot",
        "ServiceCollectionExtensions",
        "StartupExtensions",
        "ConfigureServices",
        "Module",
        "AppModule",
        "ContainerModule"
      ]
    }
  }
}

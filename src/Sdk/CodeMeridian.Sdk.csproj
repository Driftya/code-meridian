<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <RootNamespace>CodeMeridian.Sdk</RootNamespace>

    <!-- NuGet metadata — publish this so any project can reference it -->
    <PackageId>CodeMeridian.Sdk</PackageId>
    <Version>1.0.0</Version>
    <Description>Client SDK for connecting your project agent to the CodeMeridian orchestration service.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.*" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.*" />
  </ItemGroup>
</Project>

{
  "Logging": {
    "Console": { "FormatterName": "json" },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Extensions.Http": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "KeywordEnrichment": {
    "Enabled": true,
    "MinimumKeywordLength": 4,
    "MaximumKeywordsPerNode": 40,
    "MinimumSharedKeywords": 3,
    "MinimumScore": 0.25,
    "MaximumDocumentFrequencyRatio": 0.35,
    "BatchSize": 500,
    "AllowedShortTerms": [
      "api",
      "mcp",
      "cli",
      "sdk",
      "jwt",
      "sql",
      "ast",
      "ef",
      "ts"
    ],
    "AdditionalStopwords": []
  }
}

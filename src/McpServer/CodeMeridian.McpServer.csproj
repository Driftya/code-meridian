<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <RootNamespace>CodeMeridian.McpServer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Application\CodeMeridian.Application.csproj" />
    <ProjectReference Include="..\Infrastructure\CodeMeridian.Infrastructure.csproj" />
    <ProjectReference Include="..\Sdk\CodeMeridian.Sdk.csproj" />
    <ProjectReference Include="..\Tooling\CodeMeridian.Tooling.csproj" />

    <!--
      MCP SDK — exposes this service as a tool provider that GitHub Copilot
      (or any MCP-compatible client) can call directly. No LLM API key needed.
    -->
    <PackageReference Include="HotChocolate.AspNetCore" Version="16.*" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.*" />
    <PackageReference Include="Microsoft.OpenApi" Version="2.10.0" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" Version="1.*" />
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" Version="10.*" />
  </ItemGroup>
</Project>

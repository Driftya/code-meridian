# Neo4j credentials
NEO4J_PASSWORD=CodeMeridian

# Neo4j ports (offset from default 7474/7687 to avoid conflicts with other Neo4j instances)
NEO4J_HTTP_PORT=47474
NEO4J_BOLT_PORT=47687

# Port that VS Code connects to for the MCP server
# Must match the 'url' in .vscode/mcp.json
CodeMeridian_PORT=5100

# Base URL used by the local C# and TypeScript indexers.
# For a remote server, use for example: http://192.168.10.70:5100
CodeMeridian_Url=http://localhost:5100

# Optional public access API key.
# Leave empty for local development without auth.
# When set, clients must send: Authorization: Bearer <value>
CodeMeridian_Auth_ApiKey=

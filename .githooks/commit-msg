#!/bin/sh

commit_msg_file="$1"
commit_msg="$(head -n 1 "$commit_msg_file")"

max_length=72

if [ -z "$commit_msg" ]; then
  echo "Commit message cannot be empty."
  exit 1
fi

if [ ${#commit_msg} -gt $max_length ]; then
  echo "Commit message is too long: ${#commit_msg} characters."
  echo "Maximum allowed: $max_length characters."
  echo "Message: $commit_msg"
  exit 1
fi

case "$commit_msg" in
  feat:\ *|fix:\ *|docs:\ *|test:\ *|refactor:\ *|chore:\ *|ci:\ *|perf:\ *|style:\ *)
    exit 0
    ;;
  *)
    echo "Invalid commit message format."
    echo ""
    echo "Use:"
    echo "  type: short description"
    echo ""
    echo "Allowed types:"
    echo "  feat, fix, docs, test, refactor, chore, ci, perf, style"
    echo ""
    echo "Examples:"
    echo "  feat: add stale knowledge query"
    echo "  fix: prevent empty graph snapshot"
    echo "  docs: add mcp setup notes"
    exit 1
    ;;
esac
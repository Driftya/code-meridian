# Neo4j credentials
NEO4J_PASSWORD=CodeMeridian

# Neo4j host (default localhost)
NEO4J_HOST=localhost

# Neo4j ports (offset from default 7474/7687 to avoid conflicts with other Neo4j instances)
NEO4J_HTTP_PORT={{neo4jHttpPort}}
NEO4J_BOLT_PORT={{neo4jBoltPort}}

# Embedding vector dimensions for Neo4j indexes.
# Set to 768 for Ollama nomic-embed-text, or 1536 for OpenAI text-embedding-3-small.
Neo4j__EmbeddingDimensions=1536

# Port that VS Code connects to for the MCP server.
# Must match the URL in .vscode/mcp.json and .codex/config.toml.
CODEMERIDIAN_PORT={{port}}

# Base URL used by the local C# and TypeScript indexers.
# For a remote server, use for example: http://192.168.10.70:5100
CodeMeridian_Url=http://{{host}}:{{port}}

# Optional project context name used by the indexer when --project is omitted.
CodeMeridian_Project=

# API key required by the MCP server.
# Clients must send: Authorization: Bearer <value>
# Must match the token exposed via the process environment variable
# CodeMeridian_Auth_ApiKey.
CodeMeridian_Auth_ApiKey={{apiKey}}

# Optional: Vector embeddings for semantic code similarity (find_similar_nodes)
# Disabled by default (no cost, no external dependencies)
# Set these on the CodeMeridian backend to enable and choose a provider below
Embedding__Enabled=false

# Embedding provider used by the backend: Ollama (local, free), OpenAI (cloud, paid), or Stub (testing)
# Default: Ollama when enabled
Embedding__Provider=Ollama

# Ollama configuration (backend-side embedding generation, recommended)
# Requires: ollama serve reachable from the backend
# Recommended model: nomic-embed-text (768 dims, best balance of speed and quality)
# Faster alternative: all-minilm (384 dims, faster for CI/dev)
Embedding__OllamaBaseUrl=http://host.docker.internal:11434
Embedding__OllamaModel=nomic-embed-text

# OpenAI configuration (cloud-hosted, $0.02 per 1M tokens)
# Uncomment and set your API key to use OpenAI instead of Ollama
# Embedding__Provider=OpenAI
# Embedding__OpenAiApiKey=sk-proj-...
